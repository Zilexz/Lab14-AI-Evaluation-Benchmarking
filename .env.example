# Sao chép file này thành .env rồi điền key để chấm bằng MODEL THẬT.
# Nếu để trống -> hệ thống chạy chế độ OFFLINE deterministic (vẫn ra đủ report).

# --- OpenAI ---
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Hoặc dùng endpoint tương thích OpenAI (FPT AI Marketplace / OpenRouter ...) ---
# OPENAI_API_KEY=<your-key>
# OPENAI_BASE_URL=https://mkp-api.fptcloud.com   # ví dụ FPT AI Marketplace
# Khi đó đặt JUDGE model trong main.py / SDG_MODEL về model mà endpoint hỗ trợ
# (vd: glm-4-plus, gpt-4o, claude-3-5-sonnet...).
